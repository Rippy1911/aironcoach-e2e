{
  "name": "aironcoach-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end test suite for airon.coach (Playwright + Chromium). Runs against the deployed Base44 app over real HTTPS.",
  "scripts": {
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:auth-setup": "tsx e2e/auth-setup.ts",
    "e2e:auth-password": "tsx e2e/password-login-setup.ts",
    "e2e:smoke": "playwright test smoke-",
    "e2e:promo": "PROMO_CAPTURE=1 playwright test --project=promo --project=promo-mobile --reporter=list && node scripts/collect-promo-assets.mjs",
    "e2e:install": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
