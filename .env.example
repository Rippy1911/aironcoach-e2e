# =============================================================================
# AIron.coach E2E test environment
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env — it's gitignored.

# -----------------------------------------------------------------------------
# Target URL
# -----------------------------------------------------------------------------
# Default: STAGING. Use this until RELEASE_CHECKLIST.md B1 is resolved
# (Stripe Live PLN payment methods are not yet activated as of 2026-05-08, so
#  Stripe checkout will return 500 against the production host).
BASE_URL=https://break-through-ai.base44.app

# Production (after launch):
# BASE_URL=https://airon.coach

# Preview deploy (set BASE_URL to this in CI for PR builds):
# BASE_URL=https://<APP_ID>.preview.base44.app

# -----------------------------------------------------------------------------
# Base44 app identity
# -----------------------------------------------------------------------------
# Get this from the Base44 dashboard for the airon-coach app, or read it from
# the deployed app's /index.html (window.__APP_PARAMS__).
BASE44_APP_ID=

# Optional: backend functions URL pattern. Inferred from BASE_URL if unset.
# BASE44_APP_BASE_URL=https://break-through-ai.base44.app

# -----------------------------------------------------------------------------
# Test account emails
# -----------------------------------------------------------------------------
# These accounts must exist in the Base44 app's user table BEFORE running tests.
# Each account needs storage state captured once via:
#   npm run e2e:auth-setup -- --slot=<slot>
#
# IMPORTANT: do NOT put real personal email passwords in this file. The auth
# setup script opens a browser; you log in interactively, the SDK stores the
# token, and we capture the resulting cookies/localStorage to e2e/.auth/<slot>.json.
# Passwords never touch the repo.
#
# Personal account override (e.g. xrivosx@gmail.com) — fine to set as the value
# of any *_EMAIL var below; it just labels which slot that account is mapped to.
# Please use that account ONLY for the slot where its UserProfile state matches
# (e.g. if it's currently on a 14-day PRO trial, map it to TEST_PRO_EMAIL).

TEST_FREE_EMAIL=e2e-free@aironcoach-test.com
TEST_PRO_EMAIL=e2e-pro@aironcoach-test.com
TEST_ADMIN_EMAIL=e2e-admin@aironcoach-test.com
TEST_FRESH_EMAIL=e2e-fresh@aironcoach-test.com

# -----------------------------------------------------------------------------
# Stripe test mode
# -----------------------------------------------------------------------------
# Setting this enables premium-upgrade.spec.ts. Leave empty to skip the spec.
# The deployed app's STRIPE_SECRET_KEY MUST start with `sk_test_` for the
# function to resolve test price IDs (createCheckoutSession auto-detects via
# the secret prefix).
STRIPE_TEST_KEY=
STRIPE_TEST_CARD=4242424242424242

# -----------------------------------------------------------------------------
# PayU sandbox (optional)
# -----------------------------------------------------------------------------
# Set to 1 to enable payu-upgrade.spec.ts. Requires PayU sandbox panel to have
# Notification URL set to <BASE_URL>/api/functions/payuWebhook.
# See aironcoach/src/docs/RELEASE_CHECKLIST.md B2 for the full setup.
PAYU_E2E=

# -----------------------------------------------------------------------------
# Promo capture
# -----------------------------------------------------------------------------
# Set to 1 when you want the `promo` Playwright project to record video +
# full-page screenshots to ./promo-assets/. See:
#   npm run e2e:promo
PROMO_CAPTURE=

# -----------------------------------------------------------------------------
# Run config
# -----------------------------------------------------------------------------
# Set to 1 to run headed locally for debugging:
# HEADED=1

# If Playwright's bundled Chromium crashes (SIGSEGV) in your environment
# (some sandboxes / VMs), use a system browser instead:
#   PLAYWRIGHT_CHANNEL=chrome   # requires Google Chrome in default path, or:
#   npx playwright install chrome
# PLAYWRIGHT_CHANNEL=chrome

# Set to a subset of slots to skip slot setup (comma-separated):
# E2E_SKIP_SLOTS=admin
